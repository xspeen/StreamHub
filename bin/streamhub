#!/usr/bin/env bash
# StreamHub - Main Launcher Script
# Works on Linux, macOS, Termux, Git Bash, WSL
set -uo pipefail

# ---- Resolve script location ----
# Use readlink to follow symlinks (critical on Termux where bin/streamhub
# is symlinked from $PREFIX/bin/streamhub -> ~/.streamhub/bin/streamhub)
resolve_link() {
    local src="$1"
    while [ -L "$src" ]; do
        local dir
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        # If readlink returned a relative path, resolve it
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    echo "$src"
}
SELF="$(resolve_link "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SRC_DIR="$BASE_DIR/src"
WEB_DIR="$BASE_DIR/web"
DATA_DIR="$BASE_DIR/data"

# ---- Colors ----
setup_colors() {
    if [ -t 1 ] && [ -n "${TERM:-}" ] && [ "${TERM:-}" != "dumb" ]; then
        RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
        BLUE='\033[0;34m'; CYAN='\033[0;36m'; WHITE='\033[1;37m'
        DIM='\033[2m'; BOLD='\033[1m'; NC='\033[0m'
    else
        RED='' GREEN='' YELLOW='' BLUE='' CYAN='' WHITE='' DIM='' BOLD='' NC=''
    fi
}
setup_colors

# ---- Ensure data directory ----
mkdir -p "$DATA_DIR" 2>/dev/null

# ---- ASCII Banner ----
show_banner() {
    echo ""
    echo -e "  ${CYAN}═══════════════════════════════════════════${NC}"
    echo ""
    echo -e "     ${WHITE}${BOLD}S T R E A M H U B${NC}"
    echo -e "     ${DIM}Free Live TV Streaming${NC}"
    echo ""
    echo -e "  ${CYAN}═══════════════════════════════════════════${NC}"
    echo ""
}

# ---- Progress bar with percentage ----
show_progress() {
    local label="${1:-Loading}"
    local total=20
    local pct=0
    local filled=""
    local empty=""
    local i

    for ((i=0; i<=total; i++)); do
        pct=$((i * 100 / total))
        filled=""
        empty=""
        for ((j=0; j<i; j++)); do filled="${filled}█"; done
        for ((j=i; j<total; j++)); do empty="${empty}░"; done
        printf "\r  ${CYAN}  %s  ${WHITE}[${GREEN}%s${DIM}%s${WHITE}] ${WHITE}%3d%%${NC}" "$label" "$filled" "$empty" "$pct"
        sleep 0.04
    done
    echo ""
}

# ---- Loading animation with dots ----
show_loading() {
    local msg="${1:-Loading}"
    local dots=""
    for i in 1 2 3; do
        dots="${dots}."
        printf "\r  ${DIM}  %s%s${NC}" "$msg" "$dots"
        sleep 0.3
    done
    printf "\r  ${DIM}  %s   ${NC}" "$msg"
    echo ""
}

# ---- Version ----
VERSION="2.0.5"
GITHUB_REPO="xspeen/StreamHub"

# ---- Help ----
show_help() {
    echo ""
    echo -e "  ${CYAN}═══════════════════════════════════════════${NC}"
    echo ""
    echo -e "     ${WHITE}${BOLD}S T R E A M H U B${NC}  ${DIM}v${VERSION}${NC}"
    echo ""
    echo -e "  ${CYAN}═══════════════════════════════════════════${NC}"
    echo ""
    echo -e "  ${WHITE}Usage:${NC}"
    echo -e "    streamhub [command]"
    echo ""
    echo -e "  ${WHITE}Commands:${NC}"
    echo -e "    ${GREEN}(none)${NC}     Launch server and open in browser"
    echo -e "    ${GREEN}--help${NC}      Show this help message"
    echo -e "    ${GREEN}--stop${NC}      Stop any running server"
    echo -e "    ${GREEN}--reset${NC}     Reset profile and passcode"
    echo -e "    ${GREEN}--version${NC}   Show version number"
    echo -e "    ${GREEN}--update${NC}    Update to latest version"
    echo ""
}

# ---- Check Python ----
find_python() {
    for candidate in python3 python; do
        if command -v "$candidate" >/dev/null 2>&1; then
            local ver
            ver=$("$candidate" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
            local major minor
            major=$(echo "$ver" | cut -d. -f1)
            minor=$(echo "$ver" | cut -d. -f2)
            if [ "$major" -ge 3 ] && [ "$minor" -ge 7 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done
    return 1
}

# ---- Detect browser open command ----
get_open_cmd() {
    if [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux" 2>/dev/null; then
        if command -v termux-open-url >/dev/null 2>&1; then
            echo "termux-open-url"
        elif command -v am >/dev/null 2>&1; then
            echo "am start -a android.intent.action.VIEW -d"
        else
            echo ""
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        echo "open"
    elif command -v xdg-open >/dev/null 2>&1; then
        echo "xdg-open"
    elif command -v sensible-browser >/dev/null 2>&1; then
        echo "sensible-browser"
    else
        echo ""
    fi
}

# ---- Open browser ----
open_browser() {
    local url="$1"
    local cmd
    cmd=$(get_open_cmd)
    if [ -n "$cmd" ]; then
        if [ "$cmd" = "am start -a android.intent.action.VIEW -d" ]; then
            $cmd "$url" >/dev/null 2>&1 || true
        else
            $cmd "$url" >/dev/null 2>&1 || true
        fi
    fi
}

# ---- Find free port ----
find_port() {
    local port=8080
    while [ $port -le 8090 ]; do
        if ! ss -tln 2>/dev/null | grep -q ":$port " && \
           ! netstat -tln 2>/dev/null | grep -q ":$port " && \
           ! lsof -i ":$port" >/dev/null 2>&1; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done
    echo "8080"
    return 0
}

# ---- Get machine local IP (works on Linux, macOS, Termux, WSL, Git Bash) ----
get_local_ip() {
    local ip=""

    # Method 1: Try connecting to an external IP to find our interface IP
    # This works on almost every platform including Termux
    if command -v python3 >/dev/null 2>&1 || command -v python >/dev/null 2>&1; then
        local py_cmd="python3"
        command -v python3 >/dev/null 2>&1 || py_cmd="python"
        ip=$("$py_cmd" -c "
import socket
try:
    s = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    s.connect(('8.8.8.8', 80))
    print(s.getsockname()[0])
    s.close()
except:
    pass
" 2>/dev/null)
    fi

    # Method 2: ip route (Linux, Termux with root or certain configs)
    if [ -z "$ip" ] && command -v ip >/dev/null 2>&1; then
        ip=$(ip route get 8.8.8.8 2>/dev/null | awk '{for(i=1;i<=NF;i++) if($i=="src") print $(i+1); exit}')
    fi

    # Method 3: ifconfig (Linux, macOS, some Termux)
    if [ -z "$ip" ] && command -v ifconfig >/dev/null 2>&1; then
        ip=$(ifconfig 2>/dev/null | grep -oE 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1' | awk '{print $2}' | head -1)
    fi

    # Method 4: ip addr show (pick first non-loopback inet addr)
    if [ -z "$ip" ] && command -v ip >/dev/null 2>&1; then
        ip=$(ip -4 addr show 2>/dev/null | grep -oE 'inet ([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1' | head -1 | awk '{print $2}')
    fi

    # Method 5: hostname -I (many Linux distros)
    if [ -z "$ip" ]; then
        ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    fi

    # Method 6: scutil (macOS)
    if [ -z "$ip" ] && command -v scutil >/dev/null 2>&1; then
        ip=$(scutil --nwi 2>/dev/null | grep "address" | grep -oE '([0-9]*\.){3}[0-9]*' | head -1)
    fi

    # Method 7: PowerShell (Windows Git Bash)
    if [ -z "$ip" ] && command -v powershell.exe >/dev/null 2>&1; then
        ip=$(powershell.exe -Command "Get-NetIPAddress -AddressFamily IPv4 | Where-Object {\$_.InterfaceAlias -notlike '*Loopback*' -and \$_.IPAddress -ne '127.0.0.1'} | Select-Object -First 1 -ExpandProperty IPAddress" 2>/dev/null | tr -d '\r')
    fi

    # Method 8: Termux-specific - get WiFi IP from dumpsys
    if [ -z "$ip" ] && command -v dumpsys >/dev/null 2>&1; then
        ip=$(dumpsys connectivity 2>/dev/null | grep -oE 'LinkAddress.*([0-9]*\.){3}[0-9]*' | grep -oE '([0-9]*\.){3}[0-9]*' | head -1)
    fi

    # Method 9: Termux - parse ip addr for wlan0 or rmnet
    if [ -z "$ip" ] && command -v ip >/dev/null 2>&1; then
        for iface in wlan0 rmnet_data0 eth0; do
            ip=$(ip addr show "$iface" 2>/dev/null | grep -oE 'inet ([0-9]*\.){3}[0-9]*' | awk '{print $2}' | head -1)
            [ -n "$ip" ] && break
        done
    fi

    # Fallback: always works but browser on same device can reach it
    if [ -z "$ip" ]; then
        ip="127.0.0.1"
    fi

    echo "$ip"
}

# ---- Detect default browser ----
detect_browser() {
    # Termux / Android
    if [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux" 2>/dev/null; then
        echo "termux"
        return
    fi
    # macOS
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
        return
    fi
    # Windows Git Bash / MSYS
    if [[ "$OSTYPE" == "msys" ]] || [[ "$OSTYPE" == "cygwin" ]] || [[ -n "${MINGW_PREFIX:-}" ]]; then
        echo "windows"
        return
    fi
    # Linux: check xdg-settings
    if command -v xdg-settings >/dev/null 2>&1; then
        local browser
        browser=$(xdg-settings get default-web-browser 2>/dev/null)
        if [ -n "$browser" ]; then
            if echo "$browser" | grep -qi "chrome"; then echo "chrome"; return; fi
            if echo "$browser" | grep -qi "firefox"; then echo "firefox"; return; fi
            if echo "$browser" | grep -qi "edge"; then echo "edge"; return; fi
            if echo "$browser" | grep -qi "chromium"; then echo "chromium"; return; fi
        fi
    fi
    # Check which browsers are installed
    for b in google-chrome google-chrome-stable chromium chromium-browser firefox microsoft-edge; do
        if command -v "$b" >/dev/null 2>&1; then
            echo "$b"
            return
        fi
    done
    echo "xdg"
}

# ---- Open browser (universal) ----
open_browser_url() {
    local url="$1"
    local browser_type
    browser_type=$(detect_browser)

    if [ "$browser_type" = "termux" ]; then
        # Termux: try termux-open-url first, then am start, then open-url
        if command -v termux-open-url >/dev/null 2>&1; then
            termux-open-url "$url" 2>/dev/null && return 0
        fi
        if command -v am >/dev/null 2>&1; then
            am start -a android.intent.action.VIEW -d "$url" -t "android.intent.action.VIEW" 2>/dev/null && return 0
        fi
        if command -v open-url >/dev/null 2>&1; then
            open-url "$url" 2>/dev/null && return 0
        fi
    elif [ "$browser_type" = "macos" ]; then
        open "$url" 2>/dev/null && return 0
    elif [ "$browser_type" = "windows" ]; then
        cmd.exe /c start "" "$url" 2>/dev/null && return 0
    elif [ "$browser_type" = "chrome" ]; then
        google-chrome --new-window "$url" 2>/dev/null && return 0
        google-chrome-stable --new-window "$url" 2>/dev/null && return 0
    elif [ "$browser_type" = "firefox" ]; then
        firefox --new-window "$url" 2>/dev/null && return 0
    elif [ "$browser_type" = "edge" ]; then
        microsoft-edge --new-window "$url" 2>/dev/null && return 0
    elif [ "$browser_type" = "chromium" ]; then
        chromium --new-window "$url" 2>/dev/null && return 0
        chromium-browser --new-window "$url" 2>/dev/null && return 0
    fi

    # Final fallback: xdg-open (Linux), open (macOS), start (Windows)
    if command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url" 2>/dev/null && return 0
    fi
    if command -v open >/dev/null 2>&1; then
        open "$url" 2>/dev/null && return 0
    fi
    return 1
}

# ---- Stop server ----
stop_server() {
    local pids
    pids=$(pgrep -f "streamhub.*server.py" 2>/dev/null || true)
    if [ -z "$pids" ]; then
        pids=$(pgrep -f "python.*server.py.*$DATA_DIR" 2>/dev/null || true)
    fi
    if [ -n "$pids" ]; then
        echo "$pids" | while read -r pid; do
            kill "$pid" 2>/dev/null || true
        done
        sleep 0.5
        echo -e "  ${GREEN}  Server stopped.${NC}"
    else
        echo -e "  ${DIM}  No server is running.${NC}"
    fi
}

# ---- Reset profile ----
reset_profile() {
    echo ""
    echo -e "  ${RED}  This will delete your profile and passcode.${NC}"
    echo ""
    read -r -p "  Are you sure? (y/N): " confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        rm -f "$DATA_DIR/config.json" "$DATA_DIR/profile.json" "$DATA_DIR/channels_cache.json" 2>/dev/null
        echo -e "  ${GREEN}  Profile has been reset.${NC}"
    else
        echo -e "  ${DIM}  Cancelled.${NC}"
    fi
}

# ---- Check for updates ----
check_for_updates() {
    local remote_version=""
    # Fetch latest version from GitHub
    if command -v curl >/dev/null 2>&1; then
        remote_version=$(curl -sSL --max-time 5 "https://raw.githubusercontent.com/$GITHUB_REPO/main/VERSION" 2>/dev/null | tr -d '[:space:]')
    elif command -v wget >/dev/null 2>&1; then
        remote_version=$(wget -qO- --timeout=5 "https://raw.githubusercontent.com/$GITHUB_REPO/main/VERSION" 2>/dev/null | tr -d '[:space:]')
    fi

    # If we couldn't fetch, just continue silently
    if [ -z "$remote_version" ]; then
        return 0
    fi

    # Compare versions
    if [ "$remote_version" = "$VERSION" ]; then
        return 0
    fi

    # New version available - prompt user
    echo ""
    echo -e "  ${CYAN}  New version available!${NC}"
    echo -e "  ${DIM}  Current:${NC} ${WHITE}v${VERSION}${NC}"
    echo -e "  ${DIM}  Latest:${NC}  ${GREEN}v${remote_version}${NC}"
    echo ""
    echo -e "  ${DIM}  Press Enter to update, or type 'skip' to continue${NC}"
    echo ""
    read -r -p "    > " choice

    if [ "$choice" = "skip" ] || [ "$choice" = "Skip" ] || [ "$choice" = "SKIP" ]; then
        echo -e "  ${DIM}  Skipping update...${NC}"
        echo ""
        return 0
    fi

    # Perform the update
    echo ""
    echo -e "  ${CYAN}  Updating to v${remote_version}...${NC}"
    echo ""

    local install_sh
    install_sh=$(mktemp)
    if command -v curl >/dev/null 2>&1; then
        curl -sSL -o "$install_sh" "https://raw.githubusercontent.com/$GITHUB_REPO/main/install.sh"
    elif command -v wget >/dev/null 2>&1; then
        wget -q -O "$install_sh" "https://raw.githubusercontent.com/$GITHUB_REPO/main/install.sh"
    else
        echo -e "  ${RED}  Neither curl nor wget found.${NC}"
        return 1
    fi
    chmod +x "$install_sh"
    bash "$install_sh"
    rm -f "$install_sh"

    # Show success
    echo ""
    echo -e "  ${GREEN}  Updated to v${remote_version} successfully!${NC}"
    echo -e "  ${DIM}  Run 'streamhub' to start the latest version.${NC}"
    echo ""
    exit 0
}

# ---- Update ----
do_update() {
    echo ""
    echo -e "  ${CYAN}  Updating StreamHub...${NC}"
    echo ""
    show_progress "Downloading"
    local install_sh
    install_sh=$(mktemp)
    if command -v curl >/dev/null 2>&1; then
        curl -sSL -o "$install_sh" "https://raw.githubusercontent.com/xspeen/StreamHub/main/install.sh"
    elif command -v wget >/dev/null 2>&1; then
        wget -q -O "$install_sh" "https://raw.githubusercontent.com/xspeen/StreamHub/main/install.sh"
    else
        echo -e "  ${RED}  Neither curl nor wget found.${NC}"
        exit 1
    fi
    chmod +x "$install_sh"
    bash "$install_sh"
    rm -f "$install_sh"
}

# ---- First-run setup ----
first_run_setup() {
    local py="$1"
    show_banner
    show_progress "Setting up"
    echo ""

    echo -e "  ${CYAN}┌─────────────────────────────────────┐${NC}"
    echo -e "  ${CYAN}│${NC}  ${WHITE}${BOLD}Welcome to StreamHub!${NC}               ${CYAN}│${NC}"
    echo -e "  ${CYAN}│${NC}  ${DIM}Create your admin account below${NC}     ${CYAN}│${NC}"
    echo -e "  ${CYAN}└─────────────────────────────────────┘${NC}"
    echo ""

    # Create passcode with validation
    while true; do
        echo -e "  ${WHITE}Create passcode${NC} ${DIM}(min 4 characters)${NC}"
        read -r -s -p "    > " pass1
        echo ""
        # Validate passcode
        if [ ${#pass1} -lt 4 ]; then
            echo -e "  ${RED}  x  Must be at least 4 characters${NC}"
            echo ""
            continue
        fi
        # Check for repeated characters (e.g., "aaaa", "1111")
        if echo "$pass1" | "$py" -c "import sys,re;sys.exit(0 if re.match(r'^(.)\\1+$',sys.stdin.read().strip()) else 1)" 2>/dev/null; then
            echo -e "  ${RED}  x  Cannot be all repeated characters${NC}"
            echo ""
            continue
        fi
        echo -e "  ${WHITE}Confirm passcode${NC}"
        read -r -s -p "    > " pass2
        echo ""
        if [ "$pass1" = "$pass2" ]; then
            echo -e "  ${GREEN}  OK  Passcode set!${NC}"
            break
        else
            echo -e "  ${RED}  x  Passcodes do not match${NC}"
            echo ""
        fi
    done

    # Hash and save passcode
    local hash
    hash=$(echo -n "$pass1" | "$py" -c "import sys,hashlib;print(hashlib.sha256(sys.stdin.buffer.read()).hexdigest())")
    "$py" -c "
import json, os, datetime
cfg = {'passcode_hash': '$hash', 'port': 8080, 'theme': 'dark'}
with open(os.path.join('$DATA_DIR', 'config.json'), 'w') as f:
    json.dump(cfg, f, indent=2)
"

    echo ""
    echo -e "  ${WHITE}Enter your display name${NC}"
    read -r -p "    > " dname
    [ -z "$dname" ] && dname="User"

    # Get first letter as avatar
    avatar="${dname:0:1}"
    avatar=$(echo "$avatar" | tr '[:lower:]' '[:upper:]')

    # Save profile
    "$py" -c "
import json, os, datetime
now = datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
profile = {
    'name': '''$dname''',
    'avatar': '$avatar',
    'created_at': now,
    'last_login': now
}
with open(os.path.join('$DATA_DIR', 'profile.json'), 'w') as f:
    json.dump(profile, f, indent=2)
"

    echo ""
    show_progress "Saving profile"
    echo -e "  ${GREEN}  Account ready!${NC}"
    echo ""
}

# ---- Subsequent run ----
subsequent_run() {
    local py="$1"
    show_banner
    show_progress "Loading"
    echo ""

    local dname
    dname=$("$py" -c "
import json, os
p = os.path.join('$DATA_DIR', 'profile.json')
if os.path.exists(p):
    with open(p) as f:
        d = json.load(f)
    print(d.get('name', 'User'))
else:
    print('User')
" 2>/dev/null || echo "User")

    # Update last_login
    "$py" -c "
import json, os, datetime
p = os.path.join('$DATA_DIR', 'profile.json')
if os.path.exists(p):
    with open(p) as f:
        d = json.load(f)
    d['last_login'] = datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
    with open(p, 'w') as f:
        json.dump(d, f, indent=2)
" 2>/dev/null || true

    echo -e "  ${GREEN}Welcome back${NC} ${WHITE}${dname}${NC}"
    echo ""
}

# ---- Server PID file ----
save_pid() {
    echo "$$" > "$DATA_DIR/.server_pid" 2>/dev/null
}
remove_pid() {
    rm -f "$DATA_DIR/.server_pid" 2>/dev/null
}

# ---- Launch server ----
launch_server() {
    local py="$1"
    local port
    port=$(find_port)
    local ip
    ip=$(get_local_ip)

    # Clear terminal and show fresh banner
    clear 2>/dev/null || true
    show_banner

    show_progress "Starting server"
    echo ""

    save_pid

    # Trap SIGINT for clean exit
    trap 'echo ""; echo -e "  ${YELLOW}  Server stopped.${NC}"; kill $server_pid 2>/dev/null; remove_pid; exit 0' INT TERM

    # Start the Python server in the background
    "$py" "$SRC_DIR/server.py" --port "$port" --data "$DATA_DIR" --web "$WEB_DIR" &
    local server_pid=$!

    # Wait for server to be ready (up to 5 seconds)
    local waited=0
    while [ $waited -lt 50 ]; do
        if curl -s --max-time 1 "http://127.0.0.1:$port/" >/dev/null 2>&1; then
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done

    local url="http://${ip}:${port}"
    echo ""
    echo -e "  ${GREEN}  StreamHub is live!${NC}"
    echo -e "  ${WHITE}  ${url}${NC}"
    echo -e "  ${DIM}  Press Ctrl+C to stop${NC}"
    echo ""

    # Auto-open browser (works on all platforms)
    open_browser_url "$url" 2>/dev/null

    # Bring server to foreground
    wait "$server_pid" 2>/dev/null
}

# ---- Main ----
main() {
    local py
    py=$(find_python)
    if [ -z "$py" ]; then
        echo -e "  ${RED}  Python 3.7+ is required but not found.${NC}"
        echo -e "  ${DIM}  Install from python.org or your package manager.${NC}"
        exit 1
    fi

    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --stop)
            stop_server
            exit 0
            ;;
        --reset)
            reset_profile
            exit 0
            ;;
        --version|-v)
            echo -e "  StreamHub v${VERSION}"
            exit 0
            ;;
        --update)
            do_update
            exit 0
            ;;
        "")
            # Check for updates before launching
            check_for_updates

            # Check for existing profile
            if [ -f "$DATA_DIR/profile.json" ]; then
                subsequent_run "$py"
            else
                first_run_setup "$py"
            fi
            launch_server "$py"
            ;;
        *)
            echo -e "  ${RED}  Unknown command: $1${NC}"
            echo -e "  ${DIM}  Run 'streamhub --help' for usage.${NC}"
            exit 1
            ;;
    esac
}

main "$@"
