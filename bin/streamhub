#!/usr/bin/env bash
# StreamHub - Main Launcher Script
# Works on Linux, macOS, Termux, Git Bash, WSL
set -uo pipefail

# ---- Resolve script location ----
# Use readlink to follow symlinks (critical on Termux where bin/streamhub
# is symlinked from $PREFIX/bin/streamhub -> ~/.streamhub/bin/streamhub)
resolve_link() {
    local src="$1"
    while [ -L "$src" ]; do
        local dir
        dir="$(cd -P "$(dirname "$src")" && pwd)"
        src="$(readlink "$src")"
        # If readlink returned a relative path, resolve it
        [[ "$src" != /* ]] && src="$dir/$src"
    done
    echo "$src"
}
SELF="$(resolve_link "${BASH_SOURCE[0]}")"
SCRIPT_DIR="$(cd "$(dirname "$SELF")" && pwd)"
BASE_DIR="$(cd "$SCRIPT_DIR/.." && pwd)"
SRC_DIR="$BASE_DIR/src"
WEB_DIR="$BASE_DIR/web"
DATA_DIR="$BASE_DIR/data"

# ---- Colors ----
setup_colors() {
    if [ -t 1 ] && [ -n "${TERM:-}" ] && [ "${TERM:-}" != "dumb" ]; then
        RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
        BLUE='\033[0;34m'; CYAN='\033[0;36m'; WHITE='\033[1;37m'
        DIM='\033[2m'; BOLD='\033[1m'; NC='\033[0m'
    else
        RED='' GREEN='' YELLOW='' BLUE='' CYAN='' WHITE='' DIM='' BOLD='' NC=''
    fi
}
setup_colors

# ---- Ensure data directory ----
mkdir -p "$DATA_DIR" 2>/dev/null

# ---- ASCII Banner ----
show_banner() {
    echo ""
    echo -e "  ${BLUE}"
    echo "     _____ _               _                   "
    echo "    / ____| |             | |                  "
    echo "   | (___ | |__   __ _  __| | _____      _____ "
    echo "    \___ \| '_ \ / _\` |/ _\` |/ _ \ \ /\ / / _ \\"
    echo "    ____) | | | | (_| | (_| | (_) \ V  V /  __/"
    echo "   |_____/|_| |_|\__,_|\__,_|\___/ \_/\_/ \___|"
    echo -e "  ${NC}"
}

# ---- LIVE animation ----
show_live() {
    local chars="L  I  V  E"
    local displayed=""
    printf "  ${RED}"
    for ((i=0; i<${#chars}; i++)); do
        if [ "${chars:$i:1}" != " " ]; then
            displayed="${displayed}${chars:$i:1}"
            printf "\r  LIVE  [%s]" "$displayed"
            sleep 0.12
        else
            displayed="${displayed} "
            printf "\r  LIVE  [%s]" "$displayed"
        fi
    done
    printf "${NC}\r"
    echo -e "  ${RED}LIVE${NC}                                    "
    sleep 0.3
}

# ---- Version ----
VERSION="2.0.2"

# ---- Help ----
show_help() {
    echo ""
    echo -e "  ${BOLD}${CYAN}StreamHub${NC} v${VERSION} - Free Live TV Streaming"
    echo ""
    echo -e "  ${WHITE}Usage:${NC} streamhub [command]"
    echo ""
    echo -e "  ${WHITE}Commands:${NC}"
    echo "    (no args)    Launch StreamHub server and open in browser"
    echo "    --help       Show this help message"
    echo "    --stop       Stop any running StreamHub server"
    echo "    --reset      Reset profile and passcode (prompts for confirmation)"
    echo "    --version    Show version number"
    echo "    --update     Update StreamHub to latest version from GitHub"
    echo ""
}

# ---- Check Python ----
find_python() {
    for candidate in python3 python; do
        if command -v "$candidate" >/dev/null 2>&1; then
            local ver
            ver=$("$candidate" --version 2>&1 | grep -oE '[0-9]+\.[0-9]+' | head -1)
            local major minor
            major=$(echo "$ver" | cut -d. -f1)
            minor=$(echo "$ver" | cut -d. -f2)
            if [ "$major" -ge 3 ] && [ "$minor" -ge 7 ]; then
                echo "$candidate"
                return 0
            fi
        fi
    done
    return 1
}

# ---- Detect browser open command ----
get_open_cmd() {
    if [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux" 2>/dev/null; then
        if command -v termux-open-url >/dev/null 2>&1; then
            echo "termux-open-url"
        elif command -v am >/dev/null 2>&1; then
            echo "am start -a android.intent.action.VIEW -d"
        else
            echo ""
        fi
    elif [[ "$OSTYPE" == "darwin"* ]]; then
        echo "open"
    elif command -v xdg-open >/dev/null 2>&1; then
        echo "xdg-open"
    elif command -v sensible-browser >/dev/null 2>&1; then
        echo "sensible-browser"
    else
        echo ""
    fi
}

# ---- Open browser ----
open_browser() {
    local url="$1"
    local cmd
    cmd=$(get_open_cmd)
    if [ -n "$cmd" ]; then
        if [ "$cmd" = "am start -a android.intent.action.VIEW -d" ]; then
            $cmd "$url" >/dev/null 2>&1 || true
        else
            $cmd "$url" >/dev/null 2>&1 || true
        fi
    fi
}

# ---- Find free port ----
find_port() {
    local port=8080
    while [ $port -le 8090 ]; do
        if ! ss -tln 2>/dev/null | grep -q ":$port " && \
           ! netstat -tln 2>/dev/null | grep -q ":$port " && \
           ! lsof -i ":$port" >/dev/null 2>&1; then
            echo "$port"
            return 0
        fi
        port=$((port + 1))
    done
    echo "8080"
    return 0
}

# ---- Get machine local IP ----
get_local_ip() {
    local ip=""
    # Try common methods to get the local network IP
    if command -v ip >/dev/null 2>&1; then
        ip=$(ip route get 1 2>/dev/null | awk '{print $7; exit}')
    fi
    if [ -z "$ip" ] && command -v ifconfig >/dev/null 2>&1; then
        ip=$(ifconfig 2>/dev/null | grep -oE 'inet (addr:)?([0-9]*\.){3}[0-9]*' | grep -v '127.0.0.1' | awk '{print $2}' | head -1)
    fi
    if [ -z "$ip" ]; then
        ip=$(hostname -I 2>/dev/null | awk '{print $1}')
    fi
    if [ -z "$ip" ]; then
        ip="127.0.0.1"
    fi
    echo "$ip"
}

# ---- Detect default browser ----
detect_browser() {
    if [ -n "${PREFIX:-}" ] && echo "$PREFIX" | grep -q "com.termux" 2>/dev/null; then
        echo "termux"
        return
    fi
    if [[ "$OSTYPE" == "darwin"* ]]; then
        echo "macos"
        return
    fi
    # Linux: check xdg-settings
    if command -v xdg-settings >/dev/null 2>&1; then
        local browser
        browser=$(xdg-settings get default-web-browser 2>/dev/null)
        if [ -n "$browser" ]; then
            if echo "$browser" | grep -qi "chrome"; then echo "chrome"; return; fi
            if echo "$browser" | grep -qi "firefox"; then echo "firefox"; return; fi
            if echo "$browser" | grep -qi "edge"; then echo "edge"; return; fi
            if echo "$browser" | grep -qi "chromium"; then echo "chromium"; return; fi
        fi
    fi
    # Check which browsers are installed
    for b in google-chrome google-chrome-stable chromium chromium-browser firefox microsoft-edge; do
        if command -v "$b" >/dev/null 2>&1; then
            echo "$b"
            return
        fi
    done
    echo "xdg"
}

# ---- Stop server ----
stop_server() {
    local pids
    pids=$(pgrep -f "streamhub.*server.py" 2>/dev/null || true)
    if [ -z "$pids" ]; then
        pids=$(pgrep -f "python.*server.py.*$DATA_DIR" 2>/dev/null || true)
    fi
    if [ -n "$pids" ]; then
        echo "$pids" | while read -r pid; do
            kill "$pid" 2>/dev/null || true
        done
        sleep 0.5
        echo -e "${GREEN}[OK]${NC} StreamHub server stopped."
    else
        echo -e "${YELLOW}[INFO]${NC} No StreamHub server is running."
    fi
}

# ---- Reset profile ----
reset_profile() {
    echo ""
    echo -e "${YELLOW}[WARNING]${NC} This will delete your profile and passcode."
    read -r -p "  Are you sure? (y/N): " confirm
    if [ "$confirm" = "y" ] || [ "$confirm" = "Y" ]; then
        rm -f "$DATA_DIR/config.json" "$DATA_DIR/profile.json" "$DATA_DIR/channels_cache.json" 2>/dev/null
        echo -e "${GREEN}[OK]${NC} Profile has been reset."
    else
        echo -e "${DIM}Cancelled.${NC}"
    fi
}

# ---- Update ----
do_update() {
    echo ""
    echo -e "${CYAN}Updating StreamHub...${NC}"
    local install_sh
    install_sh=$(mktemp)
    if command -v curl >/dev/null 2>&1; then
        curl -sSL -o "$install_sh" "https://raw.githubusercontent.com/xspeen/StreamHub/main/install.sh"
    elif command -v wget >/dev/null 2>&1; then
        wget -q -O "$install_sh" "https://raw.githubusercontent.com/xspeen/StreamHub/main/install.sh"
    else
        echo -e "${RED}[ERROR] Neither curl nor wget found.${NC}"
        exit 1
    fi
    chmod +x "$install_sh"
    bash "$install_sh"
    rm -f "$install_sh"
}

# ---- First-run setup ----
first_run_setup() {
    local py="$1"
    show_banner
    show_live
    echo ""

    # Create passcode with validation
    while true; do
        read -r -s -p "  Create your StreamHub admin passcode: " pass1
        echo ""
        # Validate passcode
        if [ ${#pass1} -lt 4 ]; then
            echo -e "  ${RED}Passcode must be at least 4 characters. Try again.${NC}"
            echo ""
            continue
        fi
        # Check for repeated characters (e.g., "aaaa", "1111")
        if echo "$pass1" | "$py" -c "import sys,re;sys.exit(0 if re.match(r'^(.)\\1+$',sys.stdin.read().strip()) else 1)" 2>/dev/null; then
            echo -e "  ${RED}Passcode cannot be all repeated characters. Try again.${NC}"
            echo ""
            continue
        fi
        read -r -s -p "  Confirm passcode: " pass2
        echo ""
        if [ "$pass1" = "$pass2" ]; then
            break
        else
            echo -e "  ${RED}Passcodes do not match. Try again.${NC}"
            echo ""
        fi
    done

    # Hash and save passcode
    local hash
    hash=$(echo -n "$pass1" | "$py" -c "import sys,hashlib;print(hashlib.sha256(sys.stdin.buffer.read()).hexdigest())")
    "$py" -c "
import json, os, datetime
cfg = {'passcode_hash': '$hash', 'port': 8080, 'theme': 'dark'}
with open(os.path.join('$DATA_DIR', 'config.json'), 'w') as f:
    json.dump(cfg, f, indent=2)
"

    # Get display name
    read -r -p "  Enter your display name: " dname
    [ -z "$dname" ] && dname="User"

    # Get first letter as avatar
    avatar="${dname:0:1}"
    avatar=$(echo "$avatar" | tr '[:lower:]' '[:upper:]')

    # Save profile
    "$py" -c "
import json, os, datetime
now = datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
profile = {
    'name': '''$dname''',
    'avatar': '$avatar',
    'created_at': now,
    'last_login': now
}
with open(os.path.join('$DATA_DIR', 'profile.json'), 'w') as f:
    json.dump(profile, f, indent=2)
"

    echo ""
    echo -e "  ${GREEN}[OK]${NC} Account created and saved to device"
    echo ""
}

# ---- Subsequent run ----
subsequent_run() {
    local py="$1"
    show_banner
    show_live
    echo ""

    local dname
    dname=$("$py" -c "
import json, os
p = os.path.join('$DATA_DIR', 'profile.json')
if os.path.exists(p):
    with open(p) as f:
        d = json.load(f)
    print(d.get('name', 'User'))
else:
    print('User')
" 2>/dev/null || echo "User")

    # Update last_login
    "$py" -c "
import json, os, datetime
p = os.path.join('$DATA_DIR', 'profile.json')
if os.path.exists(p):
    with open(p) as f:
        d = json.load(f)
    d['last_login'] = datetime.datetime.now(datetime.timezone.utc).isoformat().replace('+00:00', 'Z')
    with open(p, 'w') as f:
        json.dump(d, f, indent=2)
" 2>/dev/null || true

    echo -e "  Welcome back, ${WHITE}${dname}${NC}"
    echo ""
}

# ---- Server PID file ----
save_pid() {
    echo "$$" > "$DATA_DIR/.server_pid" 2>/dev/null
}
remove_pid() {
    rm -f "$DATA_DIR/.server_pid" 2>/dev/null
}

# ---- Launch server ----
launch_server() {
    local py="$1"
    local port
    port=$(find_port)
    local ip
    ip=$(get_local_ip)
    local browser_type
    browser_type=$(detect_browser)

    # Clear terminal and show fresh banner
    clear 2>/dev/null || true
    show_banner

    echo -e "  ${GREEN}[OK]${NC} Starting StreamHub server..."
    echo ""

    save_pid

    # Trap SIGINT for clean exit
    trap 'echo ""; echo -e "  ${YELLOW}[OK]${NC} StreamHub stopped."; kill $server_pid 2>/dev/null; remove_pid; exit 0' INT TERM

    # Start the Python server in the background briefly to open browser
    "$py" "$SRC_DIR/server.py" --port "$port" --data "$DATA_DIR" --web "$WEB_DIR" &
    local server_pid=$!

    # Wait for server to be ready (up to 3 seconds)
    local waited=0
    while [ $waited -lt 30 ]; do
        if curl -s "http://127.0.0.1:$port/" >/dev/null 2>&1; then
            break
        fi
        sleep 0.1
        waited=$((waited + 1))
    done

    # Auto-open browser with the machine's IP address (not localhost)
    local url="http://${ip}:${port}"
    echo -e "  ${GREEN}StreamHub is running at ${WHITE}${url}${NC}"
    echo -e "  ${DIM}Press Ctrl+C to stop${NC}"
    echo ""

    # Open the default browser
    if [ "$browser_type" = "termux" ]; then
        if command -v termux-open-url >/dev/null 2>&1; then
            termux-open-url "$url" >/dev/null 2>&1 || true
        elif command -v am >/dev/null 2>&1; then
            am start -a android.intent.action.VIEW -d "$url" >/dev/null 2>&1 || true
        fi
    elif [ "$browser_type" = "macos" ]; then
        open "$url" >/dev/null 2>&1 || true
    elif [ "$browser_type" = "chrome" ]; then
        google-chrome --new-window "$url" >/dev/null 2>&1 || \
        google-chrome-stable --new-window "$url" >/dev/null 2>&1 || true
    elif [ "$browser_type" = "firefox" ]; then
        firefox --new-window "$url" >/dev/null 2>&1 || true
    elif [ "$browser_type" = "edge" ]; then
        microsoft-edge --new-window "$url" >/dev/null 2>&1 || true
    elif [ "$browser_type" = "chromium" ]; then
        chromium --new-window "$url" >/dev/null 2>&1 || \
        chromium-browser --new-window "$url" >/dev/null 2>&1 || true
    elif command -v xdg-open >/dev/null 2>&1; then
        xdg-open "$url" >/dev/null 2>&1 || true
    fi

    # Bring server to foreground
    wait "$server_pid" 2>/dev/null
}

# ---- Main ----
main() {
    local py
    py=$(find_python)
    if [ -z "$py" ]; then
        echo -e "${RED}[ERROR] Python 3.7+ is required but not found.${NC}"
        echo -e "${WHITE}Install it from python.org or your package manager.${NC}"
        exit 1
    fi

    case "${1:-}" in
        --help|-h)
            show_help
            exit 0
            ;;
        --stop)
            stop_server
            exit 0
            ;;
        --reset)
            reset_profile
            exit 0
            ;;
        --version|-v)
            echo "StreamHub v${VERSION}"
            exit 0
            ;;
        --update)
            do_update
            exit 0
            ;;
        "")
            # Check for existing profile
            if [ -f "$DATA_DIR/profile.json" ]; then
                subsequent_run "$py"
            else
                first_run_setup "$py"
            fi
            launch_server "$py"
            ;;
        *)
            echo -e "${RED}[ERROR] Unknown command: $1${NC}"
            echo "Run 'streamhub --help' for usage information."
            exit 1
            ;;
    esac
}

main "$@"
